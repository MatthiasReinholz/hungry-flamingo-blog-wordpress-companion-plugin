FOUNDATION_RELEASE_SOURCE_PROVIDER=github-release
FOUNDATION_RELEASE_SOURCE_REFERENCE=MatthiasReinholz/wp-plugin-base
FOUNDATION_VERSION=v1.7.12
PLUGIN_NAME="Hungry Flamingo Blog Companion"
PLUGIN_SLUG=hungry-flamingo-blog-companion
MAIN_PLUGIN_FILE=hungry-flamingo-blog-companion.php
README_FILE=readme.txt
ZIP_FILE=hungry-flamingo-blog-companion.zip
PHP_VERSION=8.2
NODE_VERSION=22
PHP_RUNTIME_MATRIX=8.2,8.3,8.4
PHP_RUNTIME_MATRIX_MODE=strict
PHPSTAN_MEMORY_LIMIT=1G
VERSION_CONSTANT_NAME=HFB_COMPANION_VERSION
POT_FILE=languages/hungry-flamingo-blog-companion.pot
POT_PROJECT_NAME="Hungry Flamingo Blog Companion"
WORDPRESS_ORG_SLUG=hungry-flamingo-blog-companion
WORDPRESS_READINESS_ENABLED=true
WORDPRESS_QUALITY_PACK_ENABLED=true
WORDPRESS_SECURITY_PACK_ENABLED=true
DISTIGNORE_FILE=.distignore
PACKAGE_INCLUDE=assets,blocks,hungry-flamingo-blog-companion.php,includes,languages,LICENSE,readme.txt,uninstall.php
